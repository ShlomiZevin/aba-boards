# Server port (optional, defaults to 3001)
PORT=3001

# Firebase - for local development, place service account JSON file at:
# server/firebase-service-account.json

# ElevenLabs API (for avatar TTS - optional)
ELEVENLABS_API_KEY=your_key_here

# OpenAI API (for avatar responses - optional)
OPENAI_API_KEY=your_key_here

# Anthropic API (for AI chat - optional)
ANTHROPIC_API_KEY=your_key_here

# PayPal (for subscription payments)
# Mode: sandbox (development) or live (production)
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MONTHLY_PLAN_ID=P-your_monthly_plan_id
PAYPAL_YEARLY_PLAN_ID=P-your_yearly_plan_id
PAYPAL_WEBHOOK_ID=your_webhook_id

# App base URL (used for PayPal return URLs)
APP_BASE_URL=https://your-domain.com
